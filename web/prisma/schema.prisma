generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factChangeRuns FactChangeRun[]
}

model Hospital {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facts     FactValue[]

  periods   HospitalPeriod[]

  factChangeRuns FactChangeRun[]
}

model Period {
  id        String   @id @default(cuid())
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facts     FactValue[]

  hospitals HospitalPeriod[]

  factChangeRuns FactChangeRun[]

  @@unique([year])
}

model HospitalPeriod {
  hospitalId String
  periodId   String
  createdAt  DateTime @default(now())

  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  period     Period   @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@id([hospitalId, periodId])
  @@index([periodId])
}

enum StatementType {
  BALANCE_ASSET
  BALANCE_LIAB
  INCOME_STATEMENT_UKV
  INCOME_STATEMENT_GKV
  CASHFLOW
}

enum Unit {
  EUR
  PERCENT
  COUNT
}

model LineItem {
  code          String        @id
  label         String
  statementType StatementType
  parentCode    String?
  sortOrder     Int           @default(0)

  unit          Unit          @default(EUR)
  isInput       Boolean       @default(true)

  @@unique([statementType, sortOrder])
}

model FactValue {
  id          String   @id @default(cuid())
  hospitalId  String
  periodId    String
  lineItemCode String
  value       Decimal? @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  period      Period   @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([hospitalId, periodId])
  @@index([lineItemCode])
  @@unique([hospitalId, periodId, lineItemCode])
}

model FactChangeRun {
  id           String            @id @default(cuid())
  hospitalId   String
  periodId     String
  statementType StatementType
  userId       String?
  createdAt    DateTime          @default(now())

  hospital     Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  period       Period            @relation(fields: [periodId], references: [id], onDelete: Cascade)
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  changes      FactChange[]

  @@index([hospitalId, periodId, statementType, createdAt])
}

model FactChange {
  id           String         @id @default(cuid())
  runId        String
  hospitalId   String
  periodId     String
  statementType StatementType
  lineItemCode String
  unit         Unit
  beforeValue  Decimal?       @db.Decimal(18, 2)
  afterValue   Decimal?       @db.Decimal(18, 2)
  createdAt    DateTime       @default(now())

  run          FactChangeRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([hospitalId, periodId, statementType, lineItemCode])
}

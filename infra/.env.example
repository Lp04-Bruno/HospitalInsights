# --- Postgres (container) ---
POSTGRES_DB=hospitalinsights
POSTGRES_USER=hospitalinsights
POSTGRES_PASSWORD=hospitalinsights_pw

# --- App / Prisma (container) ---
DATABASE_URL=postgresql://hospitalinsights:hospitalinsights_pw@db:5432/hospitalinsights?schema=public

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
# Generate a strong secret for any non-trivial usage
NEXTAUTH_SECRET=dev_secret_change_me

# --- Metabase signed embedding ---
# This URL is used in the iframe src (browser-visible).
# - Local dev: http://localhost:3001
# - Production: https://metabase.<your-domain>
METABASE_SITE_URL=http://localhost:3001
METABASE_EMBED_SECRET=dev_metabase_embed_secret_change_me
METABASE_DASHBOARD_ID=1

# Optional: control what users can pick on the landing page.
# Supports both dashboards and questions.
# Example:
# METABASE_DASHBOARD_CATALOG=[{"type":"dashboard","id":3,"name":"UKV Overview","hospitalParamKey":"text"},{"type":"question","id":38,"name":"Top Metrics Latest Year","hospitalParamKey":"hospitalId"}]
METABASE_DASHBOARD_CATALOG=

# Field filter parameter name used inside Metabase (SQL variable name / dashboard filter slug)
# Defaults to 'hospitalId' if unset.
METABASE_EMBED_HOSPITAL_PARAM=hospitalId

# --- Dev ergonomics ---
WATCHPACK_POLLING=true

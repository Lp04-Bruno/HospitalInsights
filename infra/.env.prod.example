# --- Postgres (production container) ---
# Use strong values and store them as Dokploy secrets / env vars.
POSTGRES_DB=hospitalinsights
POSTGRES_USER=hospitalinsights
POSTGRES_PASSWORD=change_me_strong

# App talks to Postgres over the internal docker network (service name `db`).
DATABASE_URL=postgresql://hospitalinsights:change_me_strong@db:5432/hospitalinsights?schema=public

# --- NextAuth (production) ---
# Public URL of your portal
NEXTAUTH_URL=https://hospitalinsights.de
NEXTAUTH_SECRET=change_me_strong_random

# --- Metabase signed embedding (production) ---
# IMPORTANT: This is browser-visible (iframe src). Use the public Metabase domain.
METABASE_SITE_URL=https://metabase.hospitalinsights.de

# Set these AFTER Metabase is running and you enabled embedding + created/imported dashboards.
METABASE_EMBED_SECRET=
METABASE_DASHBOARD_ID=
METABASE_DASHBOARD_CATALOG=
METABASE_EMBED_HOSPITAL_PARAM=hospitalId

# Optional: set true if you want to control migration execution manually
SKIP_DB_MIGRATIONS=false

# --- DB Backups (production) ---
# Backups are written to this directory inside the app container.
BACKUP_DIR=/backups

# Enable/disable backups feature.
BACKUP_ENABLED=true

# Enable/disable restore (dangerous operation). Consider setting to false in prod.
BACKUP_RESTORE_ENABLED=false

# Auto daily backup on /dashboard/backups load. Consider setting to true in prod.
BACKUP_AUTO_DAILY=true

# If true: /api/health will also ensure the daily backup exists.
# Usually keep this false in production.
BACKUP_AUTO_ON_HEALTH=false

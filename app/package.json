{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npx prisma generate && node scripts/fix-prisma-client-windows.mjs && node scripts/bootstrap-dev-db.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node scripts/prepare-husky.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.15.0",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "6.15.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "prisma generate && node scripts/fix-prisma-client-windows.mjs && npx ts-node --transpile-only -P prisma/tsconfig.seed.json prisma/seed.ts"
  }
}
